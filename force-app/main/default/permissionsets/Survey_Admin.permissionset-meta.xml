    <label>Survey Admin / Author</label>
    <license>Salesforce</license>

    <classAccesses>
        <apexClass>SurveyController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>SurveyService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>SurveyExportController</apexClass>
        <enabled>true</enabled>
    </classAccesses>

