<?xml version="1.0" encoding="UTF-8" ?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <description
  >Full management of Surveys, Questions, Answer Options and access to the authoring tool. Grants read access on Survey_Response/Question_Response for review.</description>
